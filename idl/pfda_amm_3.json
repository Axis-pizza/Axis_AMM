        {"name": "windowSlots", "type": "u64le", "offset": 240},
        {"name": "currentBatchId", "type": "u64le", "offset": 248},
        {"name": "currentWindowEnd", "type": "u64le", "offset": 256},
        {"name": "treasury", "type": "pubkey", "offset": 264},
