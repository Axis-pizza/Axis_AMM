        {"name": "batchId", "type": "u64le", "offset": 40},
        {"name": "clearingPrices", "type": "u64le[3]", "offset": 48, "description": "Q32.32 per-token clearing prices."},
        {"name": "totalOut", "type": "u64le[3]", "offset": 72},
        {"name": "totalIn", "type": "u64le[3]", "offset": 96},
        {"name": "feeBps", "type": "u16le", "offset": 120, "description": "Snapshot of pool.baseFeeBps at clear time."},
        {"name": "isCleared", "type": "u8", "offset": 122},
